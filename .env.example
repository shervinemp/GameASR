# Required
NEO4J_PASSWORD="your_neo4j_password"

# LLM API keys (needed when using litellm backend with OpenAI/Gemini/Anthropic)
# OPENAI_API_KEY="sk-..."
# GEMINI_API_KEY="..."
# ANTHROPIC_API_KEY="..."

# Required only when binding RPC/tools server to a non-loopback interface
# (must be at least 32 characters)
# RPC_AUTH_TOKEN="change-me-to-a-random-secret"
# TOOLS_AUTH_TOKEN="change-me-to-another-random-secret"
