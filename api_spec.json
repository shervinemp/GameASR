    "functions": [
        {
            "type": "function",
            "function": {
                "name": "move_unit",
                "description": "Moves a specified unit to a target location.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "string",
                            "description": "The name of the unit to move (e.g., \"player\", \"alpha\")."
                        },
                        "x": {
                            "type": "number",
                            "description": "The target x-coordinate."
                        },
                        "y": {
                            "type": "number",
                            "description": "The target y-coordinate."
                        }
                    },
                    "required": [
                        "name",
                        "x",
                        "y"
                    ],
                    "additionalProperties": false
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "command_unit",
                "description": "Commands a unit to perform an action, like shooting.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "string",
                            "description": "The name of the unit to command."
                        },
                        "action": {
                            "type": "string",
                            "description": "The action to perform (e.g., \"shoot\")."
                        },
                        "target_x": {
                            "type": "number",
                            "description": "The x-coordinate for the action's target."
                        },
                        "target_y": {
                            "type": "number",
                            "description": "The y-coordinate for the action's target."
                        }
                    },
                    "required": [
                        "name",
                        "action",
                        "target_x",
                        "target_y"
                    ],
                    "additionalProperties": false
                }
            }
        },
        {
